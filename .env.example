# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=reservation_system

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Application
PORT=3000
NODE_ENV=development

# Numéro réservé praticien (chiffres), identique au champ phone du user ADMIN — défaut 123456
CABINET_ACCESS_PHONE=123456

# Frontend URL (QR codes, CORS HTTP + Socket.IO)
# Local :
FRONTEND_URL=http://localhost:5173
# Production : URL exacte du site (HTTPS), sans slash final.
# Ex. https://dentardv.vercel.app
# Si plusieurs domaines : https://a.app,https://www.a.app
# Important pour le temps réel : sans ça, certains hébergeurs bloquent les connexions cross-origin.
